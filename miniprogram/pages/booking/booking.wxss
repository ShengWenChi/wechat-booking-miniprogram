/* pages/booking/booking.wxss */

/* 日期滚动 */
.date-scroll {
  width: 100%;
}

.date-list {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 4rpx 8rpx;
  white-space: nowrap;
}

.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: #FFF5EE;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.date-item.selected {
  background: #C9956A;
  border-color: #C9956A;
}

.date-weekday {
  font-size: 20rpx;
  color: #A0784A;
}

.date-item.selected .date-weekday,
.date-item.selected .date-day,
.date-item.selected .date-month {
  color: #FFFFFF;
}

.date-day {
  font-size: 40rpx;
  font-weight: 700;
  color: #5C3D2E;
  line-height: 1.2;
  margin: 6rpx 0;
}

.date-month {
  font-size: 20rpx;
  color: #A0784A;
}

/* 区块标题 */
.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #5C3D2E;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #C9956A;
}

.optional-label {
  font-size: 22rpx;
  color: #BDBDBD;
  font-weight: 400;
}

/* 预约类型选择 */
.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 18rpx;
  background: #FFF5EE;
  border: 2rpx solid transparent;
}

.type-btn.selected {
  background: #FFF0E6;
  border-color: #C9956A;
}

.type-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #5C3D2E;
  margin-bottom: 4rpx;
}

.type-btn.selected .type-name {
  color: #C9956A;
}

.type-price {
  font-size: 26rpx;
  font-weight: 800;
  color: #C9956A;
  margin-bottom: 6rpx;
}

.type-btn.selected .type-price {
  color: #A0784A;
}

.type-desc {
  font-size: 18rpx;
  color: #A0784A;
  text-align: center;
  line-height: 1.4;
}

/* 小时容量格子 */
.hour-grid-loading {
  text-align: center;
  color: #BDBDBD;
  font-size: 24rpx;
  padding: 24rpx 0;
}

.hour-scroll {
  width: 100%;
  margin-bottom: 20rpx;
}

.hour-list {
  display: flex;
  gap: 12rpx;
  padding: 4rpx 2rpx 8rpx;
}

/* 小时卡片 */
.hour-chip {
  flex-shrink: 0;
  width: 96rpx;
  padding: 16rpx 0;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  border: 2rpx solid transparent;
}

.chip-hour {
  font-size: 26rpx;
  font-weight: 600;
}

.chip-avail {
  font-size: 20rpx;
}

/* 颜色：按剩余名额 */
.chip-low  { background: #E8F5E9; border-color: #A5D6A7; }
.chip-low .chip-hour  { color: #2E7D32; }
.chip-low .chip-avail { color: #43A047; }

.chip-mid  { background: #FFF3E0; border-color: #FFCC80; }
.chip-mid .chip-hour  { color: #E65100; }
.chip-mid .chip-avail { color: #FB8C00; }

.chip-high { background: #FFEBEE; border-color: #EF9A9A; }
.chip-high .chip-hour  { color: #C62828; }
.chip-high .chip-avail { color: #E53935; }

.chip-full { background: #F5F5F5; border-color: #E0E0E0; opacity: 0.55; }
.chip-full .chip-hour  { color: #9E9E9E; }
.chip-full .chip-avail { color: #BDBDBD; }

/* 选中 */
.chip-selected {
  background: #C9956A !important;
  border-color: #C9956A !important;
}
.chip-selected .chip-hour,
.chip-selected .chip-avail {
  color: #FFFFFF !important;
}

/* 在选中范围内 */
.chip-in-range {
  background: #FFF0E6 !important;
  border-color: #F0C8A0 !important;
}
.chip-in-range .chip-hour  { color: #C9956A !important; }
.chip-in-range .chip-avail { color: #A0784A !important; }

/* 已选时间段展示条 */
.range-bar {
  display: flex;
  align-items: center;
  background: #FFF5EE;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.range-endpoint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.range-time {
  font-size: 36rpx;
  font-weight: 700;
  color: #5C3D2E;
}

.range-tip {
  font-size: 20rpx;
  color: #A0784A;
}

.range-mid {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 0 16rpx;
}

.range-dur {
  font-size: 22rpx;
  color: #C9956A;
  font-weight: 600;
}

.range-track {
  width: 100%;
  height: 4rpx;
  background: #F0D8C0;
  border-radius: 4rpx;
  position: relative;
}

.range-fill {
  position: absolute;
  left: 0; top: 0; bottom: 0; right: 0;
  background: #C9956A;
  border-radius: 4rpx;
}

/* 营业时间提示 */
.business-hours-hint {
  display: block;
  font-size: 22rpx;
  color: #A0784A;
  background: #FFF5EE;
  border-radius: 10rpx;
  padding: 8rpx 16rpx;
  margin-bottom: 20rpx;
}

/* 时间选择 */
.time-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.time-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.time-label {
  font-size: 22rpx;
  color: #A0784A;
}

.time-picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFF5EE;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #F0E8E0;
}

.time-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #5C3D2E;
}

.time-arrow-small {
  font-size: 18rpx;
  color: #C9956A;
}

.time-to {
  font-size: 32rpx;
  color: #C9956A;
  padding-bottom: 20rpx;
}

.time-auto {
  background: #F5F5F5;
  border: 2rpx solid #E0E0E0;
}

.time-auto .time-value {
  color: #9E9E9E;
}

.time-warn {
  display: block;
  font-size: 22rpx;
  color: #E57373;
  margin-top: 12rpx;
}

/* 类型说明卡片 */
.type-info-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.type-info-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.type-info-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.type-info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5C3D2E;
}

.type-info-desc {
  font-size: 24rpx;
  color: #A0784A;
  line-height: 1.6;
}

/* 名额卡片 */
.avail-card {
  padding: 20rpx 32rpx;
}

.avail-loading {
  font-size: 24rpx;
  color: #BDBDBD;
  text-align: center;
}

.avail-row {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  padding: 4rpx 0;
  border-radius: 12rpx;
}

.avail-full {
  color: #E57373;
  background: #FFEBEE;
  padding: 12rpx 24rpx;
}

.avail-ok {
  color: #4CAF50;
  background: #E8F5E9;
  padding: 12rpx 24rpx;
}

/* 人数选择 */
.people-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 20rpx 0;
}

.people-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFF0E6;
  color: #C9956A;
  font-size: 40rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #C9956A;
  padding: 0;
  line-height: 1;
}

.people-count {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.count-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #C9956A;
  line-height: 1;
}

.count-unit {
  font-size: 28rpx;
  color: #A0784A;
}

.people-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #BDBDBD;
  margin-top: 8rpx;
}

/* 表单 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: #FFF5EE;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #5C3D2E;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 100rpx;
  background: #FFF5EE;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #5C3D2E;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

/* 提交区域 */
.submit-area {
  padding: 24rpx 32rpx 40rpx;
}

.order-summary {
  text-align: center;
  font-size: 26rpx;
  color: #A0784A;
  margin-bottom: 20rpx;
}

.summary-sep {
  color: #C9956A;
}

.submit-btn {
  width: 100%;
}

.submit-btn.disabled {
  opacity: 0.6;
}
