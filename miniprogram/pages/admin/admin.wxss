/* pages/admin/admin.wxss */

/* 登录 */
.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-card {
  width: 100%;
  text-align: center;
}

.login-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.login-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #5C3D2E;
  margin-bottom: 40rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #FFF5EE;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #5C3D2E;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.login-btn {
  width: 100%;
  border-radius: 50rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
}

/* 顶栏 */
.admin-header {
  background: linear-gradient(135deg, #C9956A, #A0784A);
  padding: 32rpx 32rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.admin-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.logout-btn {
  background: rgba(255,255,255,0.2);
  color: #FFFFFF;
  border: none;
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
}

/* 日期导航 */
.date-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0E8E0;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFF0E6;
  color: #C9956A;
  border: none;
  font-size: 36rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.nav-date {
  font-size: 30rpx;
  font-weight: 700;
  color: #1C1C1E;
}

/* 统计概览 */
.stats-row {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  overflow-x: auto;
}

.stat-chip {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #F2F2F7;
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  min-width: 80rpx;
}

.chip-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C1C1E;
}

.chip-label {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}

.chip-normal   { background: #EDE7F6; }
.chip-normal .chip-num { color: #7B1FA2; }
.chip-changwan { background: #E8F5E9; }
.chip-changwan .chip-num { color: #2E7D32; }
.chip-xianban  { background: #FFF3E0; }
.chip-xianban .chip-num { color: #E65100; }

/* 特殊预约（畅玩/限板） */
.special-section {
  margin: 16rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-title-sm {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  display: block;
  margin-bottom: 14rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.special-card {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F2F7;
  gap: 16rpx;
}

.special-card:last-child {
  border-bottom: none;
}

.special-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.type-changwan .special-badge {
  background: #E8F5E9;
  color: #2E7D32;
}

.type-xianban .special-badge {
  background: #FFF3E0;
  color: #E65100;
}

.special-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.special-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1C1C1E;
}

.special-people {
  font-size: 24rpx;
  color: #8E8E93;
}

.special-contact {
  font-size: 22rpx;
  color: #C9956A;
  font-weight: 500;
}

.special-remark {
  font-size: 22rpx;
  color: #8E8E93;
}

.cancel-btn-sm {
  font-size: 20rpx;
  color: #FF3B30;
  background: #FFF0EE;
  border: none;
  border-radius: 12rpx;
  padding: 8rpx 18rpx;
  flex-shrink: 0;
}

/* 热力图 */
.heat-section {
  margin: 16rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.heat-bar {
  display: flex;
  gap: 4rpx;
  align-items: flex-end;
  height: 80rpx;
  margin-top: 12rpx;
}

.heat-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  gap: 4rpx;
}

.heat-track {
  flex: 1;
  width: 100%;
  background: #F2F2F7;
  border-radius: 4rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.heat-fill {
  width: 100%;
  border-radius: 4rpx;
  transition: height 0.3s;
}

.level-empty { background: transparent; }
.level-low   { background: #34C759; }
.level-mid   { background: #FF9500; }
.level-high  { background: #FF3B30; }

.heat-hour {
  font-size: 16rpx;
  color: #8E8E93;
}

.heat-count {
  font-size: 14rpx;
  color: #1C1C1E;
  font-weight: 600;
}

/* 时间轴 */
.loading-state {
  text-align: center;
  padding: 80rpx;
  color: #8E8E93;
  font-size: 26rpx;
}

.timeline-card {
  margin: 16rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.timeline-row {
  display: flex;
  position: relative;
}

/* 左侧时间标签列 */
.time-col {
  width: 52px;
  flex-shrink: 0;
  position: relative;
  border-right: 1px solid #F2F2F7;
}

.time-label-item {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  justify-content: flex-end;
  padding-right: 8px;
  transform: translateY(-50%);
}

.time-label-text {
  font-size: 10px;
  color: #8E8E93;
  font-weight: 400;
}

/* 右侧事件列 */
.events-col {
  flex: 1;
  position: relative;
}

.hour-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1px;
  background: #F2F2F7;
}

/* 空状态 */
.timeline-empty {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  text-align: center;
  font-size: 26rpx;
  color: #C7C7CC;
}

/* 预约块 */
.event-block {
  position: absolute;
  background: #FFF0E6;
  border-left: 4px solid #C9956A;
  border-radius: 0 8px 8px 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  overflow: hidden;
  padding: 6px 4px 6px 8px;
  box-sizing: border-box;
}

.event-inner {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
  overflow: hidden;
  min-width: 0;
}

.event-block.xianban-block {
  background: #FFF3E0;
  border-left-color: #E65100;
}

.event-name {
  font-size: 11px;
  font-weight: 700;
  color: #5C3D2E;
  white-space: nowrap;
  overflow: hidden;
}

.event-type-tag {
  font-size: 10px;
  color: #E65100;
  font-weight: 600;
}

.event-time {
  font-size: 10px;
  color: #A0784A;
  white-space: nowrap;
  overflow: hidden;
}

.event-contact {
  font-size: 11px;
  color: #C9956A;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.event-remark {
  font-size: 10px;
  color: #BDBDBD;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.event-cancel-btn {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: rgba(255,59,48,0.12);
  color: #FF3B30;
  border: none;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
  align-self: flex-start;
}

/* 已取消 */
.cancelled-row {
  margin: 16rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #F9F9F9;
  border-radius: 16rpx;
}

.cancelled-text {
  font-size: 24rpx;
  color: #C7C7CC;
}
