# 复制此文件为 .env 并填入真实配置

# 服务端口
PORT=3000

# MongoDB 连接地址
MONGODB_URI=mongodb://localhost:27017/perler_beads_reservation

# JWT 密钥（请改为随机长字符串）
JWT_SECRET=your_super_secret_jwt_key_change_this

# 微信小程序配置
WX_APPID=your_wx_appid
WX_SECRET=your_wx_app_secret

# 管理员密码（登录后台用）
ADMIN_PASSWORD=0416

# 管理员JWT密钥
ADMIN_JWT_SECRET=admin_secret_key_change_this

# 跨域允许域名（生产环境填小程序合法域名）
ALLOWED_ORIGINS=http://localhost:3000
